{
  "$schema": "https://opencode.ai/config.json",
  "skills": {
    "paths": [".opencode/skills"]
  },
  "permission": {
    "external_directory": "deny"
  },
  "provider": {
    "amazon-bedrock": {
      "models": {
        "anthropic.claude-sonnet-4-6": {
          "options": {
            "thinking": {
              "type": "enabled",
              "budgetTokens": 10000
            }
          }
        }
      }
    }
  }
}
